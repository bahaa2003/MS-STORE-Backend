NODE_ENV=development
PORT=3000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Must be a replica set for session / transaction support.
MONGO_URI=mongodb://localhost:27017/digital_products_platform

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Provider: Royal Crown ────────────────────────────────────────────────────
# Stored per-provider in the DB (Provider.baseUrl / Provider.apiToken).
# These env vars are the fallback when no DB record exists.
ROYAL_CROWN_API_URL=https://royal-croown.com
ROYAL_CROWN_API_TOKEN=your_royal_crown_api_token_here

# ─── Provider: Torosfon Store ─────────────────────────────────────────────────
# Auth: Authorization: Bearer <token>
TOROSFON_API_URL=https://torosfon.com
TOROSFON_API_TOKEN=your_torosfon_api_token_here

# ─── Provider: Alkasr VIP ─────────────────────────────────────────────────────
# Auth: X-API-Key: <token>
ALKASR_API_URL=https://alkasr-vip.com
ALKASR_API_TOKEN=your_alkasr_api_token_here

# Provider credential encryption.
# Use a stable high-entropy value in production. If omitted, JWT_SECRET is used as a fallback.
PROVIDER_CREDENTIAL_ENCRYPTION_KEY=replace_with_32_plus_random_chars
# Backward-compatible alias for older deployments. Prefer PROVIDER_CREDENTIAL_ENCRYPTION_KEY.
PROVIDER_CREDENTIALS_KEY=

# Provider: Xena Recharge
# Digiteech client API key is stored per provider in the DB, never in frontend env.
XENA_API_URL=https://api.digiteech.me
XENA_API_TIMEOUT_MS=20000
XENA_STATUS_CHECK_CONCURRENCY=3

# ─── Exchange Rate API ────────────────────────────────────────────────────────
# Used by exchangeRateSync.service.js to populate Currency.marketRate.
# Supported APIs: exchangerate.host (free, no key), openexchangerates.org (key required),
#                 exchangeratesapi.io (key required), fixer.io (key required)
#
# Default (no key needed):
#   EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest?base=USD
#
# openexchangerates.org:
#   EXCHANGE_RATE_API_URL=https://openexchangerates.org/api/latest.json?base=USD
#   EXCHANGE_RATE_API_KEY=your_openexchangerates_app_id
#
# fixer.io:
#   EXCHANGE_RATE_API_URL=https://data.fixer.io/api/latest?base=USD
#   EXCHANGE_RATE_API_KEY=your_fixer_access_key
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest?base=USD
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_TIMEOUT_MS=10000

# ─── CORS (production only) ───────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com

# ─── Receipt Analyzer (Deposit Anti-Fraud) ────────────────────────────────────
# Fast image checks are always applied to uploaded receipt images.
# OCR is optional (resource-heavy) and disabled by default.
RECEIPT_ANALYZER_ENABLE_OCR=false
RECEIPT_ANALYZER_MIN_ENTROPY=1.0
RECEIPT_ANALYZER_BLACK_MEAN_MAX=8
RECEIPT_ANALYZER_WHITE_MEAN_MIN=247
RECEIPT_ANALYZER_SOLID_STDDEV_MAX=2.5
RECEIPT_ANALYZER_LOW_ENTROPY_STDDEV_MAX=3.2
RECEIPT_ANALYZER_MAX_INPUT_PIXELS=40000000
RECEIPT_ANALYZER_OCR_TIMEOUT_MS=3500
RECEIPT_ANALYZER_OCR_RESIZE_WIDTH=1200
RECEIPT_ANALYZER_OCR_MIN_KEYWORD_MATCHES=1
RECEIPT_ANALYZER_OCR_KEYWORDS=تم,نجاح,فودافون,Vodafone,Cash,كاش,تحويل
